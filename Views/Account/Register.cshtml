@{
    ViewData["Title"] = "Créer un compte";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <h2 class="fw-bold">&#9632; Velcro</h2>
            <p class="text-muted">Créez votre espace de travail</p>
        </div>
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div id="error-msg" class="alert alert-danger d-none"></div>
                <div class="mb-3">
                    <label class="form-label">Nom d'utilisateur</label>
                    <input type="text" id="username" class="form-control" placeholder="monpseudo" autofocus>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" id="email" class="form-control" placeholder="nom@exemple.com">
                </div>
                <div class="mb-4">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" id="password" class="form-control" placeholder="8 caractères minimum">
                </div>
                <button id="btn-register" class="btn btn-success w-100">Créer mon compte</button>
                <hr class="my-3">
                <p class="text-center mb-0 small">
                    Déjà un compte ? <a href="/account/login">Se connecter</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    if (getToken()) window.location.href = '/';

    document.getElementById('btn-register').addEventListener('click', register);
    document.getElementById('password').addEventListener('keydown', e => { if (e.key === 'Enter') register(); });

    async function register() {
        const username = document.getElementById('username').value.trim();
        const email    = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const errEl    = document.getElementById('error-msg');
        errEl.classList.add('d-none');

        if (!username || !email || !password) {
            errEl.textContent = 'Veuillez remplir tous les champs.';
            errEl.classList.remove('d-none');
            return;
        }
        try {
            const res = await fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, password })
            });
            if (!res.ok) {
                const msg = await res.text();
                errEl.textContent = msg || 'Erreur lors de la création du compte.';
                errEl.classList.remove('d-none');
                return;
            }
            const data = await res.json();
            saveAuth(data.accessToken, data.user);
            window.location.href = '/';
        } catch {
            errEl.textContent = 'Erreur réseau. Réessayez.';
            errEl.classList.remove('d-none');
        }
    }
</script>
}
